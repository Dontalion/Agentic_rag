# Environment variables for Agentic RAG
# Copy this file to .env and fill in your values

# API Keys
AGENTIC_RAG_OPENAI_API_KEY=your_openai_api_key_here
AGENTIC_RAG_HUGGINGFACE_TOKEN=your_huggingface_token_here

# Model configurations
AGENTIC_RAG_MODEL_NAME=meta-llama/Llama-3.1-70B-Instruct
AGENTIC_RAG_EMBEDDING_MODEL_NAME=thenlper/gte-small
AGENTIC_RAG_TOKENIZER_MODEL_NAME=thenlper/gte-small

# Text splitting configurations
AGENTIC_RAG_CHUNK_SIZE=200
AGENTIC_RAG_CHUNK_OVERLAP=20

# Vector database configurations
AGENTIC_RAG_DISTANCE_STRATEGY=COSINE

# Search configurations
AGENTIC_RAG_SEARCH_K=5